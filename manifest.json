{
"update_url": "https://clients2.google.com/service/update2/crx",

  "manifest_version": 3,
  "name": "Ask Gemini: Contextual Replies",
  "version": "1.3.0",
  "description": "Reply with context on Gemini. Now featuring a beautiful minimalist UI and an interactive live guided tour.",
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://api2.amplitude.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Ask Gemini Settings"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/*"
      ],
      "js": [
        "content.js",
        "tour.js"
      ],
      "css": [
        "styles.css",
        "tour.css"
      ],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}