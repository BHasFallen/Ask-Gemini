{
  "manifest_version": 3,
  "name": "Quote Reply for Gemini",
  "version": "2.4.0",
  "description": "Highlight any text in Gemini. Ask a follow-up with that exact context locked in — fewer hallucinations, sharper answers.",
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://api2.amplitude.com/*",
    "https://gemini.google.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Quote Reply Settings"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/*"
      ],
      "js": [
        "content.js",
        "tour.js"
      ],
      "css": [
        "styles.css",
        "tour.css"
      ],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}